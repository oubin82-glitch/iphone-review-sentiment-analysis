<span class="n">index_content</span><span class="o">=</span><span class="nb">sum</span><span class="p">(</span><span class="n">n_content</span><span class="p">,[])</span><span class="c1">#将嵌套的列表展开，作为词所在评论的id</span>
<span class="n">seg_word</span><span class="o">=</span><span class="nb">sum</span><span class="p">(</span><span class="n">seg_word</span><span class="p">,[])</span>
<span class="n">word</span><span class="o">=</span><span class="p">[</span><span class="n">x</span><span class="p">[</span><span class="mi">0</span><span class="p">]</span> <span class="k">for</span> <span class="n">x</span> <span class="ow">in</span> <span class="n">seg_word</span><span class="p">]</span><span class="c1">#词</span>
<span class="n">nature</span><span class="o">=</span><span class="p">[</span><span class="n">x</span><span class="p">[</span><span class="mi">1</span><span class="p">]</span> <span class="k">for</span> <span class="n">x</span> <span class="ow">in</span> <span class="n">seg_word</span><span class="p">]</span><span class="c1">#词性</span>
<span class="n">content_type</span><span class="o">=</span><span class="p">[[</span><span class="n">x</span><span class="p">]</span><span class="o">*</span><span class="n">y</span> <span class="k">for</span> <span class="n">x</span><span class="p">,</span><span class="n">y</span> <span class="ow">in</span> <span class="nb">zip</span><span class="p">(</span><span class="nb">list</span><span class="p">(</span><span class="n">reviews</span><span class="p">[</span><span class="s1">'score'</span><span class="p">]),</span><span class="nb">list</span><span class="p">(</span><span class="n">n_word</span><span class="p">))]</span><span class="c1">#评论类型</span>
<span class="n">content_type</span><span class="o">=</span><span class="nb">sum</span><span class="p">(</span><span class="n">content_type</span><span class="p">,[])</span>
